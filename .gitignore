# ============================================================================
# Keep notebook directory structure
# ============================================================================

# Allow README files in notebook directory
!notebooks/README.md
!notebooks/__init__.py

# Allow source code directory structure
!src/__init__.py
!src/**/__init__.py

# Allow test directory structure
!tests/__init__.py
!tests/**/__init__.py

